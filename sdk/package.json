{
  "name": "@rerange/wagmi",
  "version": "0.0.5",
  "description": "Rerange Wagmi SDK",
  "keywords": [
    "liquid",
    "orders"
  ],
  "homepage": "https://rerange.xyz",
  "bugs": {
    "url": "https://github.com/rerange-xyz/info/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rerange-xyz/info.git"
  },
  "license": "MIT",
  "author": "rerange.xyz",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js",
      "default": "./dist/config/index.js"
    },
    "./deployments": {
      "types": "./dist/deployments.d.ts",
      "import": "./dist/deployments.js",
      "default": "./dist/deployments.js"
    },
    "./generated": {
      "types": "./dist/generated.d.ts",
      "import": "./dist/generated.js",
      "default": "./dist/generated.js"
    }
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "sync": "node ./scripts/sync.js",
    "generate": "wagmi generate --config wagmi.config.ts",
    "typecheck": "tsc --noEmit",
    "dist": "tsc -p tsconfig.build.json && node ./scripts/dist.js",
    "build": "npm run sync && npm run generate && npm run typecheck && npm run dist"
  },
  "dependencies": {
    "@wagmi/core": "^3.4.1",
    "viem": "^2.47.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@wagmi/cli": "^2.5.2",
    "typescript": "~5.8.0"
  }
}
